[Unit]
Description=Breathwork Video Library
After=network.target

[Service]
Type=simple
WorkingDirectory=__PROJECT_DIR__
ExecStart=__UV_PATH__ run uvicorn breathwork.main:app --host 0.0.0.0 --port 8765 --timeout-graceful-shutdown 2
Restart=always
RestartSec=5
TimeoutStopSec=5
Environment=PATH=/usr/local/bin:/usr/bin:/bin:%h/.local/bin

[Install]
WantedBy=default.target
